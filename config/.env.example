# =============================================================================
# Global Azure identity (inherited by every datasource unless overridden below)
# =============================================================================

# Entra ID tenant (required)
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Service principal credentials — set both or neither.
# If omitted, all datasources default to CLI auth (az login / browser).
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=your-client-secret-value

# =============================================================================
# Per-datasource auth overrides
#
# Each datasource can specify its own auth method and credentials.
# {PREFIX}_AUTH     = "sp" (service principal) | "cli" (az login)
# {PREFIX}_TENANT_ID     — overrides AZURE_TENANT_ID for this datasource
# {PREFIX}_CLIENT_ID     — overrides AZURE_CLIENT_ID for this datasource
# {PREFIX}_CLIENT_SECRET — overrides AZURE_CLIENT_SECRET for this datasource
#
# If {PREFIX}_AUTH is not set:
#   "sp"  when global AZURE_CLIENT_ID + AZURE_CLIENT_SECRET are both set
#   "cli" otherwise
#
# CLI credentials are deduplicated by tenant — if two datasources share the
# same tenant_id and both use CLI auth, az login is prompted only once.
#
# Run order: SP-authenticated datasources run first (no user interaction),
# then CLI-authenticated datasources grouped by tenant_id.
# =============================================================================

# ── Log Analytics / Application Insights ─────────────────────────────────────
# LOG_ANALYTICS_AUTH=sp
# LOG_ANALYTICS_TENANT_ID=
# LOG_ANALYTICS_CLIENT_ID=
# LOG_ANALYTICS_CLIENT_SECRET=
LOG_ANALYTICS_WORKSPACE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Azure Monitor ─────────────────────────────────────────────────────────────
# AZURE_MONITOR_AUTH=sp
# AZURE_MONITOR_TENANT_ID=
# AZURE_MONITOR_CLIENT_ID=
# AZURE_MONITOR_CLIENT_SECRET=
AZURE_MONITOR_WORKSPACE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# AZURE_MONITOR_SUBSCRIPTION_ID=   # enables Resource Graph alert queries

# ── Power Platform Admin API ──────────────────────────────────────────────────
# POWERPLATFORM_ADMIN_AUTH=sp
# POWERPLATFORM_ADMIN_TENANT_ID=
# POWERPLATFORM_ADMIN_CLIENT_ID=
# POWERPLATFORM_ADMIN_CLIENT_SECRET=
# POWERPLATFORM_ADMIN_ENVIRONMENT_ID=  # primary environment (fallback if discovery fails)
# POWERPLATFORM_ADMIN_ENV_IDS=         # comma-separated env IDs to limit agent iteration

# ── Dynamics 365 Global Discovery ────────────────────────────────────────────
# Fallback when Power Platform Admin API is unavailable.
# GLOBAL_DISCOVERY_AUTH=sp
# GLOBAL_DISCOVERY_TENANT_ID=
# GLOBAL_DISCOVERY_CLIENT_ID=
# GLOBAL_DISCOVERY_CLIENT_SECRET=

# ── Dataverse Web API ─────────────────────────────────────────────────────────
# DATAVERSE_AUTH=sp
# DATAVERSE_TENANT_ID=
# DATAVERSE_CLIENT_ID=
# DATAVERSE_CLIENT_SECRET=
DATAVERSE_URL=https://orgxxxxxxxx.crm.dynamics.com
POWERPLATFORM_ENVIRONMENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Microsoft Graph Reports API ───────────────────────────────────────────────
# GRAPH_AUTH=sp
# GRAPH_TENANT_ID=
# GRAPH_CLIENT_ID=
# GRAPH_CLIENT_SECRET=

# ── Microsoft Viva Insights ───────────────────────────────────────────────────
# VIVA_AUTH=sp
# VIVA_TENANT_ID=
# VIVA_CLIENT_ID=
# VIVA_CLIENT_SECRET=

# ── Microsoft Purview ─────────────────────────────────────────────────────────
# PURVIEW_AUTH=sp
# PURVIEW_TENANT_ID=
# PURVIEW_CLIENT_ID=
# PURVIEW_CLIENT_SECRET=
# PURVIEW_ACCOUNT_NAME=your-purview-account
# PURVIEW_ENDPOINT=             # optional — overrides the default *.purview.azure.com URL

# ── Microsoft Defender for Cloud ──────────────────────────────────────────────
# DEFENDER_AUTH=sp
# DEFENDER_TENANT_ID=
# DEFENDER_CLIENT_ID=
# DEFENDER_CLIENT_SECRET=
# DEFENDER_SUBSCRIPTION_ID=    # enables security alerts + secure score fetch
# DEFENDER_WORKSPACE_ID=       # optional — Log Analytics workspace for Defender data

# =============================================================================
# Output & storage
# =============================================================================

LOOKBACK_DAYS=30
OUTPUT_PATH=agent_telemetry.xlsx
DB_PATH=agent_telemetry.db

# Blob storage — hosts agent_telemetry.db for the deployed MCP server
AZURE_STORAGE_ACCOUNT=stagenttelemetry
AZURE_STORAGE_CONTAINER=telemetry-data
AZURE_STORAGE_DB_BLOB=agent_telemetry.db

# Optional: total M365 Copilot license count for activation-rate KPI
# TOTAL_LICENSES=500

# =============================================================================
# MCP server (HTTP deployment)
# =============================================================================

MCP_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MCP_APP_ID_URI=api://<your-tenant-id>/agent-telemetry-mcp
PORT=8000
