# Tenant that owns the Log Analytics workspace (and where the app registration lives)
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# App registration credentials
# Azure Portal → Azure Active Directory → App registrations → <your app> → Overview
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Azure Portal → App registrations → <your app> → Certificates & secrets → Client secrets
AZURE_CLIENT_SECRET=your-client-secret-value

# Log Analytics workspace that receives the Agents OTel export
# Azure Portal → Log Analytics workspaces → <your workspace> → Overview → Workspace ID
LOG_ANALYTICS_WORKSPACE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# How far back to pull telemetry (days); default 30
LOOKBACK_DAYS=30

# Where to write the Excel workbook
OUTPUT_PATH=agent_telemetry.xlsx

# SQLite database path (historical store, read by MCP agents)
DB_PATH=agent_telemetry.db

# Blob Storage — hosts agent_telemetry.db for the deployed MCP server
# Azure Portal → Storage accounts → <account> → Containers
AZURE_STORAGE_ACCOUNT=stagenttelemetry
AZURE_STORAGE_CONTAINER=telemetry-data
AZURE_STORAGE_DB_BLOB=agent_telemetry.db

# MCP server — Entra ID auth for the deployed HTTP endpoint
# MCP_TENANT_ID: the reporting tenant (same as AZURE_TENANT_ID)
# MCP_APP_ID_URI: App ID URI from the app registration → Expose an API
MCP_TENANT_ID=72e8590f-f5f5-4d75-a5f0-efb11546d57a
MCP_APP_ID_URI=api://<your-tenant-id>/agent-telemetry-mcp
PORT=8000
